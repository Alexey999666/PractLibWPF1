<Window x:Class="PractLibWPF1.AddEditReader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractLibWPF1"
        mc:Ignorable="d"
        Title="AddEditReader" Height="500" Width="600" 
        x:Name="ReaderAddEdit" Loaded="AddOrEditReader_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Label Content="№ читательского билета"/>
            <TextBox x:Name="tbCardNumber" TextWrapping="Wrap" Text="{Binding Path=LibraryCardNumber}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Label Content="ФИО"/>
            <TextBox x:Name="tbFullName" TextWrapping="Wrap" Text="{Binding Path=FullName}"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <Label Content="Адрес"/>
            <TextBox x:Name="tbAddress" TextWrapping="Wrap" Text="{Binding Path=Address}"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <Label Content="Телефон"/>
            <TextBox x:Name="tbPhone" TextWrapping="Wrap" Text="{Binding Path=Phone}"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="10">
            <CheckBox x:Name="cbIsDeleted" Content="Выбыл" VerticalAlignment="Center" 
                      IsChecked="{Binding Path=IsDeleted}"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnAddEditReader" Height="40" Width="100" Margin="10" Click="btnAddEditReader_Clicked"/>
            <Button Content="Отмена" Height="40" Width="100" Margin="10" Click="btnCancel_Clicked"/>
        </StackPanel>
    </Grid>
</Window>