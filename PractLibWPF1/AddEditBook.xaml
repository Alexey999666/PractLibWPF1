<Window x:Class="PractLibWPF1.AddEditBook"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PractLibWPF1"
        mc:Ignorable="d"
        Title="AddEditBook" Height="800" Width="600" 
        x:Name="BookAddEdit" Loaded="AddOrEditBook_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Label Content="Автор"/>
            <TextBox x:Name="tbAuthor" TextWrapping="Wrap" Text="{Binding Path=Author}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Label Content="Название"/>
            <TextBox x:Name="tbTitle" TextWrapping="Wrap" Text="{Binding Path=Title}"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <Label Content="Год издания"/>
            <TextBox x:Name="tbYear" TextWrapping="Wrap" Text="{Binding Path=YearPublished}"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <Label Content="Цена"/>
            <TextBox x:Name="tbPrice" TextWrapping="Wrap" Text="{Binding Path=Price}"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <Label Content="Аннотация"/>
            <TextBox x:Name="tbAnnotation" TextWrapping="Wrap" Text="{Binding Path=Annotation}" 
                     Height="100" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnAddEditBook" Height="40" Width="100" Margin="10" Click="btnAddEditBook_Clicked"/>
            <Button Content="Отмена" Height="40" Width="100" Margin="10" Click="btnCancel_Clicked"/>
        </StackPanel>
    </Grid>
</Window>